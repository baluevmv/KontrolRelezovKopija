		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	ЗапросыНаАкцептИБ.Ссылка КАК Ссылка,
	ЗапросыНаАкцептИБ.ВерсияДанных КАК ВерсияДанных,
