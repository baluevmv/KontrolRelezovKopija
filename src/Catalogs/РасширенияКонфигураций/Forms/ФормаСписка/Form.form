        <field>Расширение</field>
      </fields>
      <fields xsi:type="schema:DataCompositionSchemaDataSetField">
        <dataPath>АктуальнаяВерсияДатаВыхода</dataPath>
        <field>АктуальнаяВерсияДатаВыхода</field>
        <title>
