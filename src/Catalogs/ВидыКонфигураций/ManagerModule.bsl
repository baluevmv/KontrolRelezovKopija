Процедура ОписатьВидКонфигурации(ИмяПредопределенныхДанных, Наименование, Синоним, КодПрограммы) Экспорт
	
	СсылкаПредопределенного = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыКонфигураций." + ИмяПредопределенныхДанных);
	
	Если ЗначениеЗаполнено(СсылкаПредопределенного) Тогда
		Элемент = СсылкаПредопределенного.ПолучитьОбъект();
	Иначе
		Элемент = Справочники.ВидыКонфигураций.СоздатьЭлемент();
		Элемент.ИмяПредопределенныхДанных = ИмяПредопределенныхДанных;
	КонецЕсли;
	
	Если Элемент.Наименование <> Наименование Тогда
		Элемент.Наименование = Наименование;
	КонецЕсли;
	
	Если Элемент.Синоним <> Синоним Тогда
		Элемент.Синоним = Синоним;
	КонецЕсли;
	
	Если Элемент.КодПрограммы <> КодПрограммы Тогда
		Элемент.КодПрограммы = КодПрограммы;
	КонецЕсли;
	
	Если Элемент.Модифицированность() Тогда
		Элемент.ОбменДанными.Загрузка = Истина;
		Элемент.ДополнительныеСвойства.Вставить("ЗаписьОбщихДанных");
		Элемент.Записать();
	КонецЕсли;

КонецПроцедуры

