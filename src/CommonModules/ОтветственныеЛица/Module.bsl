
#Область ПрограммныйИнтерфейс

// Возвращает актуальный состав ответственных лиц за информационную базу и организацию на указанную дату
//
// Параметры:
//   ДатаРасчета - Дата - дата, на которую определяется актуальный состав
//   Организация - СправочникСсылка.Организации - организация, для которой формируется состав
//   ИнформационнаяБаза - СправочникСсылка.ИнформационныеБазы - информационная база, для которой формируется состав
//   Неопределено - если не указана, возвращаются ответственные только на уровне организации
//
// Возвращаемое значение:
//   ТаблицаЗначений:
//     * Организация - СправочникСсылка.Организации - организация
//     * ИнформационнаяБаза - СправочникСсылка.ИнформационныеБазы - информационная база
//     * Ответственный - СправочникСсылка.ОтветственныеЛица - ответственное лицо
//     * Email - Строка - email ответственного лица
//     * Телефон - Строка - телефон ответственного лица
//     * ДатаНазначения - Дата - дата назначения ответственного лица
//     * Источник - Строка - источник ответственного ("Организация" или "ИнформационнаяБаза")
Функция ПолучитьАктуальныйСостав(ДатаРасчета, Организация, ИнформационнаяБаза = Неопределено) Экспорт
	
	ПустаяИБ = Справочники.ИнформационныеБазы.ПустаяСсылка();
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДатаРасчета", ДатаРасчета);
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("ПустаяИБ", ПустаяИБ);
	
	Если ИнформационнаяБаза = Неопределено Тогда
		
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	&Организация КАК Организация,
			|	&ПустаяИБ КАК ИнформационнаяБаза,
			|	ОтветственныеЗаИБСрезПоследних.Ответственный КАК Ответственный,
			|	ОтветственныеЛица.Email КАК Email,
			|	ОтветственныеЛица.Телефон КАК Телефон,
			|	ОтветственныеЗаИБСрезПоследних.Период КАК ДатаНазначения,
			|	""Организация"" КАК Источник
			|ИЗ
			|	РегистрСведений.ОтветственныеЗаИБ.СрезПоследних(
			|			&ДатаРасчета,
			|			Организация = &Организация
			|				И ИнформационнаяБаза = &ПустаяИБ) КАК ОтветственныеЗаИБСрезПоследних
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ОтветственныеЛица КАК ОтветственныеЛица
			|		ПО ОтветственныеЗаИБСрезПоследних.Ответственный = ОтветственныеЛица.Ссылка
			|ГДЕ
			|	НЕ ОтветственныеЗаИБСрезПоследних.Исключить
			|
			|УПОРЯДОЧИТЬ ПО
			|	ДатаНазначения";
		
	Иначе
		
		Запрос.УстановитьПараметр("ИнформационнаяБаза", ИнформационнаяБаза);
		
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	Сортировка.Организация КАК Организация,
			|	Сортировка.ИнформационнаяБаза КАК ИнформационнаяБаза,
			|	Сортировка.Ответственный КАК Ответственный,
			|	Сортировка.Email КАК Email,
			|	Сортировка.Телефон КАК Телефон,
			|	Сортировка.ДатаНазначения КАК ДатаНазначения,
			|	Сортировка.Источник КАК Источник
			|ИЗ
			|	(ВЫБРАТЬ
			|		&Организация КАК Организация,
			|		&ИнформационнаяБаза КАК ИнформационнаяБаза,
			|		ЛокальныйСрез.Ответственный КАК Ответственный,
			|		ОтветственныеЛица.Email КАК Email,
			|		ОтветственныеЛица.Телефон КАК Телефон,
			|		ЛокальныйСрез.Период КАК ДатаНазначения,
			|		""ИнформационнаяБаза"" КАК Источник
			|	ИЗ
			|		РегистрСведений.ОтветственныеЗаИБ.СрезПоследних(
			|				&ДатаРасчета,
			|				Организация = &Организация
			|					И ИнформационнаяБаза = &ИнформационнаяБаза) КАК ЛокальныйСрез
			|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ОтветственныеЛица КАК ОтветственныеЛица
			|			ПО ЛокальныйСрез.Ответственный = ОтветственныеЛица.Ссылка
			|	ГДЕ
			|		НЕ ЛокальныйСрез.Исключить
			|	
			|	ОБЪЕДИНИТЬ ВСЕ
			|	
			|	ВЫБРАТЬ
			|		&Организация,
			|		&ПустаяИБ,
			|		БазовыйСрез.Ответственный,
			|		ОтветственныеЛица.Email,
			|		ОтветственныеЛица.Телефон,
			|		БазовыйСрез.Период,
			|		""Организация""
			|	ИЗ
			|		РегистрСведений.ОтветственныеЗаИБ.СрезПоследних(
			|				&ДатаРасчета,
			|				Организация = &Организация
			|					И ИнформационнаяБаза = &ПустаяИБ) КАК БазовыйСрез
			|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ОтветственныеЛица КАК ОтветственныеЛица
			|			ПО БазовыйСрез.Ответственный = ОтветственныеЛица.Ссылка
			|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ОтветственныеЗаИБ.СрезПоследних(
			|					&ДатаРасчета,
			|					Организация = &Организация
			|						И ИнформационнаяБаза = &ИнформационнаяБаза) КАК ЛокальныйСрезПроверка
			|			ПО БазовыйСрез.Ответственный = ЛокальныйСрезПроверка.Ответственный
			|	ГДЕ
			|		НЕ БазовыйСрез.Исключить
			|		И ЛокальныйСрезПроверка.Ответственный ЕСТЬ NULL) КАК Сортировка
			|
			|УПОРЯДОЧИТЬ ПО
			|	Источник УБЫВ,
			|	ДатаНазначения";
		
	КонецЕсли;
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

// Возвращает таблицу ответственных за подключение к информационным базам на указанную дату
