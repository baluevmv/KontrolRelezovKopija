					СтрокаВыборки.ШаблонПервичного);
				
				ДанныеПисьма = ШаблоныСообщений.СформироватьСообщение(
					ШаблонДляИспользования, 
					СтрокаВыборки.РасширениеКонфигурации, 
					ИдентификаторПисьма
				);
				
				Для Каждого Получатель Из Получатели Цикл
					ЗаписатьУведомлениеВЖурналРасширения(
						СтрокаВыборки, 
						Получатель, 
						ДанныеПисьма, 
						ИдентификаторСостояния, 
						ИдентификаторПисьма, 
						ТекущаяДата
					);
					КонецЦикла;	
					
				Письмо = СформироватьПисьмоСАдресомОтправителя(ДанныеПисьма, АдресОтправителя, ЭлАдресаПолучателей);
				
				ЗаписатьПисьмоВОчередь(Письмо, ТекущаяДата, ИдентификаторПисьма, ИдентификаторСостояния);


				
				ОбновитьСостояниеРасширенияПослеУведомления(СтрокаВыборки, ТекущаяДата, ИдентификаторСостояния);
				
			КонецЦикла;
			
			ЗафиксироватьТранзакцию();
		Исключение
			ОтменитьТранзакцию();
			ЗаписьЖурналаРегистрации(
				"КонтрольРелизов.ОбработкаРасширений", 
				УровеньЖурналаРегистрации.Ошибка, 
				, 
				ИнформационнаяБаза, 
				"Ошибка при формировании уведомлений для расширений: " + ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке())
			);
		КонецПопытки;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаписатьУведомлениеВЖурналРасширения(ДанныеСостояния, ПолучательСтруктура, ДанныеПисьма, ИдентификаторСостояния, ИдентификаторПисьма, ТекущаяДата)
	
	Набор = РегистрыСведений.ЖурналУведомленийОбОбновлениях.СоздатьНаборЗаписей();
	Набор.Отбор.ИнформационнаяБаза.Установить(ДанныеСостояния.ИнформациБаза);
	Набор.Отбор.РасширениеКонфигурации.Установить(ДанныеСостояния.РасширениеКонфигурации);
	
	Запись = Набор.Добавить();
	Запись.ИнформационнаяБаза = ДанныеСостояния.ИнформационнаяБаза;
	Запись.РасширениеКонфигурации = ДанныеСостояния.РасширениеКонфигурации;
	Запись.Получатель = ПолучательСтруктура.Ответственный;
	Запись.СпособУведомления = Перечисления.СпособыУведомления.ЭлектроннаяПочта;
	Запись.ИдентификаторУведомления = ИдентификаторСостояния;
	Запись.ИдентификаторПисьма = ИдентификаторПисьма;
	
	Запись.ДатаДобавления = ТекущаяДата;
	Запись.ТемаСообщения = ДанныеПисьма.Тема;
	Запись.ТекстСообщения = ДанныеПисьма.Текст;
	
	Запись.ТипУведомления = ?(ДанныеСостояния.ЭтоПовторное, 
		Перечисления.ТипыУведомлений.Повторное, 
		Перечисления.ТипыУведомлений.Первичное);
	
	Запись.НомерПовтора = ДанныеСостояния.КоличествоУведомлений + 1;
	
	Набор.Записать(Истина);
	
КонецПроцедуры

Процедура ОбновитьСостояниеРасширенияПослеУведомления(ДанныеВыборки, ТекущаяДата, ИдентификаторСостояния)
	
	Набор = РегистрыСведений.СостоянияКонтроляРасширений.СоздатьНаборЗаписей();
	Набор.Отбор.ИнформационнаяБаза.Установить(ДанныеВыборки.ИнформационнаяБаза);
	Набор.Отбор.РасширениеКонфигурации.Установить(ДанныеВыборки.РасширениеКонфигурации);
	Набор.Отбор.ВерсияРасширения.Установить(ДанныеВыборки.ВерсияРасширения);
	
	Набор.Прочитать();
	
	Если Набор.Количество() > 0 Тогда
		Запись = Набор[0];
		Запись.ДатаПоследнегоУведомления = ТекущаяДата;
		Запись.КоличествоУведомлений = Запись.КоличествоУведомлений + 1;
		Запись.ИдентификаторПоследнегоУведомления = ИдентификаторСостояния;
	Набор.Записать();
	Иначе
		Запись = Набор.Добавить();
		Запись.ИнформационнаяБаза = ДанныеВыборки.ИнформационнаяБаза;
		Запись.РасширениеКонфигурации = ДанныеВыборки.РасширениеКонфигурации;
		Запись.ВерсияРасширения = ДанныеВыборки.ВерсияРасширения;
		Запись.Статус = Перечисления.СтатусыСостояния.ПланируетсяУстановка;
		Запись.ДатаОбнаруженияВерсии = ТекущаяДата;
		Запись.ДатаКонтрольногоСрока = ДанныеВыборки.ДатаКонтрольногоСрока;
		Запись.ДатаПланируемойУстановки = ДанныеВыборки.ДатаПланируемойУстановки;
		Запись.ДатаПоследнегоУведомления = ТекущаяДата;
		Запись.КоличествоУведомлений = 1;
		Запись.ИдентификаторСостояния = ИдентификаторСостояния;
		Запись.ИдентификаторПоследнегоУведомления = ИдентификаторСостояния;
		Запись.ПринялРешение = ДанныеВыборки.ПринялРешение;
		Набор.Записать(Истина);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ТекстыЗапросов

// Возвращает адрес электронной почты системной учетной записи
//
Функция АдресСистемнойУчетнойЗаписиЭлектроннойПочты()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СУ.АдресЭлектроннойПочты КАК АдресЭлектроннойПочты
		|ИЗ
		|	Справочник.УчетныеЗаписиЭлектроннойПочты КАК СУ
		|ГДЕ
		|	СУ.Ссылка = &СистемнаяУчетнаяЗапись";
	
	Запрос.УстановитьПараметр("СистемнаяУчетнаяЗапись", Справочники.УчетныеЗаписиЭлектроннойПочты.СистемнаяУчетнаяЗаписьЭлектроннойПочты);
	
	Результат = Запрос.Выполнить();
	Если Результат.Пустой() Тогда
		Возврат "";
	КонецЕсли;
	
	Возврат Результат.Выгрузить()[0].АдресЭлектроннойПочты;
	
КонецФункции

#КонецОбласти

#Область ТекстыЗапросов

Функция ТекстЗапросаКандидатовНаУведомление()

	Возврат 
		"ВЫБРАТЬ
		|	Состояния.ИнформационнаяБаза КАК ИнформационнаяБаза,
		|	Состояния.ИнформационнаяБаза.Наименование КАК ИмяБазы,
		|	Состояния.КлючОбновления КАК КлючОбновления,
		|	Состояния.КлючОбновления.ТипОбъектаИБ КАК ТипОбъектаИБ,
		|	Состояния.КлючОбновления.ОбъектИБ КАК ОбъектИБ,
		|	Состояния.КлючОбновления.ТекущаяВерсия КАК ТекущаяВерсия,
		|	Состояния.КлючОбновления.НоваяВерсия КАК НоваяВерсия,
		|	Состояния.ДатаКонтрольногоСрока КАК ДатаКонтрольногоСрока,
		|	Состояния.КоличествоУведомлений КАК КоличествоУведомлений,
		|	ВЫБОР
		|		КОГДА Состояния.Статус = &СтатусПросрочено
		|			ТОГДА ИСТИНА
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ КАК ЭтоПовторное,
		|	Настройки.ШаблонУведомления КАК ШаблонПервичного,
		|	Настройки.ШаблонПовторногоУведомления КАК ШаблонПовторного
		|ИЗ
		|	РегистрСведений.СостоянияКонтроляРелизов КАК Состояния
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.НастройкиКонтроляРелизов КАК Настройки
		|		ПО Состояния.ИнформационнаяБаза = Настройки.ИнформационнаяБаза
		|			И Состояния.КлючОбновления.ТипОбъектаИБ = Настройки.ТипОбъектаИБ
		|			И Состояния.КлючОбновления.ОбъектИБ = Настройки.ОбъектИБ
		|ГДЕ
		|	Настройки.КонтрольАктивен = ИСТИНА
		|	И (Состояния.Статус = &СтатусПланируется
		|				И Состояния.КоличествоУведомлений = 0
		|			ИЛИ Состояния.Статус = &СтатусПросрочено
		|				И Настройки.ОтправлятьПовторныеУведомления = ИСТИНА
		|				И Состояния.КоличествоУведомлений < Настройки.МаксимальноеКоличествоПовторов
		|				И (Состояния.ДатаПоследнегоУведомления = ДАТАВРЕМЯ(1, 1, 1)
		|					ИЛИ ДОБАВИТЬКДАТЕ(Состояния.ДатаПоследнегоУведомления, ДЕНЬ, Настройки.ИнтервалПовторныхУведомленийВДнях) <= &ТекущаяДата))";
	
КонецФункции

Функция ТекстЗапросаКандидатовНаУведомлениеРасширения()

	Возврат 
		"ВЫБРАТЬ
		|	Состояния.ИнформационнаяБаза КАК ИнформациБаза,
		|	Состояния.РасширениеКонфигурации КАК РасширениеКонфигурации,
		|	Состояния.ВерсияРасширения КАК ВерсияРасширения,
		|	Состояния.Статус КАК Статус,
		|	Состояния.ДатаОбнаруженияВерсии КАК ДатаОбнаруженияВерсии,
		|	Состояния.ДатаПланируемойУстановки КАК ДатаПланируемойУстановки,
		|	Состояния.ДатаКонтрольногоСрока КАК ДатаКонтрольногоСрока,
		|	Состояния.КоличествоУведомлений КАК КоличествоУведомлений,
		|	Состояния.ПринялРешение КАК ПринялРешение,
		|	ВЫБОР
		|		КОГДА Состояния.Статус = &СтатусПросрочено
		|			ТОГДА ИСТИНА
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ КАК ЭтоПовторное,
		|	Настройки.ШаблонУведомления КАК ШаблонПервичного,
		|	Настройки.ШаблонПовторногоУведомления КАК ШаблонПовторного
		|ИЗ
		|	РегистрСведений.СостоянияКонтроляРасширений КАК Состояния
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.НастройкиКонтроляРелизов КАК Настройки
		|		ПО Состояния.ИнформационнаяБаза = Настройки.ИнформационнаяБаза
		|		И Состояния.РасширениеКонфигурации = Настройки.ОбъектИБ
		|ГДЕ
		|	Настройки.КонтрольАктивен = ИСТИНА
		|	И (Состояния.Статус = &СтатусПланируется
		|			И Состояния.КоличествоУведомлений = 0
		|		ИЛИ Состояния.Статус = &СтатусПросрочено
		|			И Настройки.ОтправлятьПовторныеУведомления = ИСТИНА
		|			И Состояния.КоличествоУведомлений < Настройки.МаксимальноеКоличествоПовторов
		|			И (Состояния.ДатаПоследнегоУведомления = ДАТАВРЕМЯ(1, 1, 1)
		|				ИЛИ ДОБАВИТЬКДАТЕ(Состояния.ДатаПоследнегоУведомления, ДЕНЬ, Настройки.ИнтервалПовторныхУведомленийВДнях) <= &ТекущаяДата))";

КонецФункции

#КонецОбласти