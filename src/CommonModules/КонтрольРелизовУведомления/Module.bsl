			ЭлементБлок.Режим = РежимБлокировкиДанных.Исключительный;
			
			Блокировка.Заблокировать();
			
			Получатели = ОтветственныеЛица.ПолучитьОтветственныхЗаРасширенияПоСпискуИБ(
