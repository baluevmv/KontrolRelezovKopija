КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедуры

Процедура ФормированиеУведомлений()
	
	ТекущаяДата = ТекущаяДатаСеанса();
	
	АдресОтправителя = АдресСистемнойУчетнойЗаписиЭлектроннойПочты();
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапросаКандидатовНаУведомление();
	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДата);
	Запрос.УстановитьПараметр("СтатусПланируется", Перечисления.СтатусыСостояния.ПланируетсяУстановка);
	Запрос.УстановитьПараметр("СтатусПросрочено", Перечисления.СтатусыСостояния.Просрочено);
	
	ТаблицаКандидатов = Запрос.Выполнить().Выгрузить();	
	Если ТаблицаКандидатов.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	УникальныеИБ = ТаблицаКандидатов.Скопировать(, "ИнформационнаяБаза");
	УникальныеИБ.Свернуть("ИнформационнаяБаза");
	
	Для Каждого СтрИБ Из УникальныеИБ Цикл
		
		ИнформационнаяБаза = СтрИБ.ИнформационнаяБаза;
		СтрокиПоИБ = ТаблицаКандидатов.НайтиСтроки(Новый Структура("ИнформационнаяБаза", ИнформационнаяБаза));
		
		Если СтрокиПоИБ.Количество() = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		НачатьТранзакцию();
		Попытка
			
			Блокировка = Новый БлокировкаДанных;
			ЭлементБлок = Блокировка.Добавить("РегистрСведений.СостоянияКонтроляРелизов");
			ЭлементБлок.УстановитьЗначение("ИнформационнаяБаза", ИнформационнаяБаза);
			ЭлементБлок.Режим = РежимБлокировкиДанных.Исключительный;
			
			ЭлементБлок = Блокировка.Добавить("РегистрСведений.ЖурналУведомленийОбОбновлениях");
			ЭлементБлок.УстановитьЗначение("ИнформационнаяБаза", ИнформационнаяБаза);
			ЭлементБлок.Режим = РежимБлокировкиДанных.Исключительный;
			
			Блокировка.Заблокировать();
			
			Получатели = ОтветственныеЛица.ПолучитьАктуальныйСостав(
				ТекущаяДата, 
				ИнформационнаяБаза.Организация,
				ИнформационнаяБаза
			);
			
			Если Получатели.Количество() = 0 Тогда
				ЗафиксироватьТранзакцию();
				Продолжить;
			КонецЕсли;
			
			ЭлАдресаПолучателей = Получатели.Скопировать(, "Email");
			ЭлАдресаПолучателей.Свернуть("Email");
			
			Для Каждого СтрокаВыборки Из СтрокиПоИБ Цикл
				
				ИдентификаторУведомления = Строка(Новый УникальныйИдентификатор);
				ИдентификаторПисьма = Строка(Новый УникальныйИдентификатор);
				
				ШаблонДляИспользования = ?(СтрокаВыборки.ЭтоПовторное, СтрокаВыборки.ШаблонПовторного, СтрокаВыборки.ШаблонПервичного);
				
				ДанныеПисьма = ШаблоныСообщений.СформироватьСообщение(ШаблонДляИспользования, СтрокаВыборки.КлючОбновления, ИдентификаторПисьма);
				
				Для Каждого Получатель Из Получатели Цикл
					ЗаписатьУведомлениеВЖурнал(
						СтрокаВыборки, 
						Получатель, 
						ДанныеПисьма, 
						ИдентификаторУведомления, 
						ИдентификаторПисьма, 
						ТекущаяДата
					);
					КонецЦикла;	
					
					Письмо = СформироватьПисьмоСАдресомОтправителя(ДанныеПисьма, АдресОтправителя, ЭлАдресаПолучателей);
					
					ЗаписатьПисьмоВОчередь(Письмо, ТекущаяДата, ИдентификаторПисьма, ИдентификаторУведомления);

				
				ОбновитьСостояниеПослеУведомления(СтрокаВыборки, ТекущаяДата);
				
			КонецЦикла;
			
			ЗафиксироватьТранзакцию();
		Исключение
			ОтменитьТранзакцию();
			ЗаписьЖурналаРегистрации(
				"КонтрольРелизов.ОбработкаИБ", 
				УровеньЖурналаРегистрации.Ошибка, 
				, 
				ИнформационнаяБаза, 
				"Ошибка при формировании уведомлений: " + ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке())
			);
		КонецПопытки;
		
	КонецЦикла;
	
КонецПроцедуры 

Функция СформироватьПисьмоСАдресомОтправителя(ДанныеПисьма, АдресОтправителя, ЭлАдресаПолучателей)
	
	Письмо = Новый ИнтернетПочтовоеСообщение;
	Письмо.Кодировка = "utf-8";
	
	Для Каждого ЭлАдрес Из ЭлАдресаПолучателей Цикл
		Письмо.Получатели.Добавить(ЭлАдрес.Email);
	КонецЦикла;
	
	Письмо.Отправитель = АдресОтправителя;
	
	Письмо.Тексты.Добавить(ДанныеПисьма.Текст, ТипТекстаПочтовогоСообщения.HTML);
	Для Каждого Текст Из Письмо.Тексты Цикл
		Текст.Кодировка = "utf-8";
	КонецЦикла;
	
	Возврат Письмо;
	
КонецФункции

Функция СформироватьПисьмо(ДанныеПисьма, УчетнаяЗапись, ЭлАдресаПолучателей)
	
	Письмо = Новый ИнтернетПочтовоеСообщение;
	Письмо.Кодировка = "utf-8";
	
	Для Каждого ЭлАдрес Из ЭлАдресаПолучателей Цикл
		Письмо.Получатели.Добавить(ЭлАдрес.Email);
	КонецЦикла;
	
	Письмо.Отправитель = УчетнаяЗапись.АдресЭлектроннойПочты;
	
	Письмо.Тексты.Добавить(ДанныеПисьма.Текст, ТипТекстаПочтовогоСообщения.HTML);
	Для Каждого Текст Из Письмо.Тексты Цикл
		Текст.Кодировка = "utf-8";
	КонецЦикла;
	
	Письмо.Тема = ДанныеПисьма.Тема;
	
	Возврат Письмо;
	
КонецФункции

Процедура ЗаписатьУведомлениеВЖурнал(ДанныеОбновления, ПолучательСтруктура, ДанныеПисьма, ИдентификаторУведомления, ИдентификаторПисьма, ТекущаяДата)
	
	Запись = РегистрыСведений.ЖурналУведомленийОбОбновлениях.СоздатьМенеджерЗаписи();
	
	Запись.ИнформационнаяБаза	= ДанныеОбновления.ИнформационнаяБаза;
	Запись.КлючОбновления		= ДанныеОбновления.КлючОбновления;
	Запись.Получатель			= ПолучательСтруктура.Ответственный; 
	Запись.СпособУведомления	= Перечисления.СпособыУведомления.ЭлектроннаяПочта;
	Запись.ИдентификаторУведомления = ИдентификаторУведомления;
	Запись.ИдентификаторПисьма	= ИдентификаторПисьма;
	
	Запись.ДатаДобавления		= ТекущаяДата;
	Запись.ТемаСообщения		= ДанныеПисьма.Тема;
	Запись.ТекстСообщения		= ДанныеПисьма.Текст;
	
	Запись.ТипУведомления = ?(ДанныеОбновления.ЭтоПовторное, 
		Перечисления.ТипыУведомлений.Повторное, 
		Перечисления.ТипыУведомлений.Первичное);
	
	Запись.НомерПовтора = ДанныеОбновления.КоличествоУведомлений + 1;
	
	Запись.Записать();
	
КонецПроцедуры

Процедура ЗаписатьПисьмоВОчередь(Письмо, ДатаДобавления, ИдентификаторПисьма, ИдентификаторУведомления)
	
	Запись = РегистрыСведений.ОчередьПисемОбОбновлениях.СоздатьМенеджерЗаписи();
	Запись.ИдентификаторПисьма		= ИдентификаторПисьма;
	Запись.ДатаДобавления			= ДатаДобавления;
	Запись.Письмо					= Новый ХранилищеЗначения(Письмо);
	Запись.ИдентификаторУведомления	= ИдентификаторУведомления;
	
	Запись.Записать();
	
КонецПроцедуры   

Процедура ОбновитьСостояниеПослеУведомления(ДанныеВыборки, ТекущаяДата)
	
	Набор = РегистрыСведений.СостоянияКонтроляРелизов.СоздатьНаборЗаписей();
	Набор.Отбор.ИнформационнаяБаза.Установить(ДанныеВыборки.ИнформационнаяБаза);
	Набор.Отбор.КлючОбновления.Установить(ДанныеВыборки.КлючОбновления);
	Набор.Прочитать();

	Если Набор.Количество() > 0 Тогда
		Запись = Набор[0];
		Запись.КоличествоУведомлений = Запись.КоличествоУведомлений + 1;
		Запись.ДатаПоследнегоУведомления = ТекущаяДата;
		Набор.Записать();
	КонецЕсли; 
	
КонецПроцедуры


Процедура ОтправитьОжидающиеПисьма()
	
	ТекущаяДата = ТекущаяДатаСеанса();
	УчетнаяЗапись = Справочники.УчетныеЗаписиЭлектроннойПочты.СистемнаяУчетнаяЗаписьЭлектроннойПочты;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Очередь.ИдентификаторПисьма КАК ИдентификаторПисьма,
		|	Очередь.ДатаДобавления КАК ДатаДобавления,
		|	Очередь.ИдентификаторУведомления КАК ИдентификаторУведомления
		|ИЗ
		|	РегистрСведений.ОчередьПисемОбОбновлениях КАК Очередь
		|ГДЕ
		|	Очередь.ДатаОтправки = ДАТАВРЕМЯ(1, 1, 1)";
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		НачатьТранзакцию();
		Попытка
			
			Блокировка = Новый БлокировкаДанных;
			ЭлементБлокировки = Блокировка.Добавить("РегистрСведений.ОчередьПисемОбОбновлениях");
			ЭлементБлокировки.УстановитьЗначение("ИдентификаторПисьма", Выборка.ИдентификаторПисьма);
			ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
			Блокировка.Заблокировать();
			
			НаборОчереди = РегистрыСведений.ОчередьПисемОбОбновлениях.СоздатьНаборЗаписей();
			НаборОчереди.Отбор.ИдентификаторПисьма.Установить(Выборка.ИдентификаторПисьма);
			НаборОчереди.Прочитать();
			
			Если НаборОчереди.Количество() = 0 Тогда
				ОтменитьТранзакцию();
				Продолжить;
			КонецЕсли;
			
			ТекущаяЗапись = НаборОчереди[0];
			Если ЗначениеЗаполнено(ТекущаяЗапись.ДатаОтправки) Тогда
			ОтменитьТранзакцию();
			Продолжить;
		КонецЕсли;
		
		Письмо = ТекущаяЗапись.Письмо.Получить();
		Если Письмо = Неопределено Тогда
			ОтменитьТранзакцию();
			Продолжить;
		КонецЕсли;
		
		// Отправка
		РаботаСПочтовымиСообщениями.ОтправитьПисьмо(УчетнаяЗапись, Письмо);

			
			// Успешно — фиксируем дату отправки
			ТекущаяЗапись.ДатаОтправки = ТекущаяДата;
			НаборОчереди.Записать();
			
			// Обновляем все связанные уведомления в журнале
			ОбновитьДатыОтправкиВЖурналеУведомлений(Выборка.ИдентификаторПисьма, ТекущаяДата);
			
			ЗафиксироватьТранзакцию();
			
		Исключение
			
			ОтменитьТранзакцию();
			
			ЗаписьЖурналаРегистрации(
				"КонтрольРелизов.ОтправкаПисьма",
				УровеньЖурналаРегистрации.Ошибка,
				,
				Выборка.ИдентификаторПисьма,
				"Ошибка отправки письма " + Выборка.ИдентификаторПисьма + ": " +
				ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке())
			);
			
			// Письмо остаётся в очереди для следующей попытки
			
		КонецПопытки;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ОбновитьДатыОтправкиВЖурналеУведомлений(ИдентификаторПисьма, ДатаОтправки)
	
	Набор = РегистрыСведений.ЖурналУведомленийОбОбновлениях.СоздатьНаборЗаписей();
	Набор.Отбор.ИдентификаторПисьма.Установить(ИдентификаторПисьма);
	Набор.Отбор.ДатаОтправки.Установить(Дата('00010101'));
	
	Набор.Прочитать();
	
	Для Каждого Запись Из Набор Цикл
		Запись.ДатаОтправки = ДатаОтправки;
	КонецЦикла;
	
	Набор.Записать(Истина);
	
КонецПроцедуры

Процедура ФормированиеУведомленийРасширения()
	
	ТекущаяДата = ТекущаяДатаСеанса();
	АдресОтправителя = АдресСистемнойУчетнойЗаписиЭлектроннойПочты();
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапросаКандидатовНаУведомлениеРасширения();
	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДата);
	Запрос.УстановитьПараметр("СтатусПланируется", Перечисления.СтатусыСостояния.ПланируетсяУстановка);
	Запрос.УстановитьПараметр("СтатусПросрочено", Перечисления.СтатусыСостояния.Просрочено);
	
