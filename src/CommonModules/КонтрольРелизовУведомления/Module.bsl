#Область ПрограммныйИнтерфейс

// Формирует уведомления для ответственных за обновления конфигурации
//
Процедура ФормированиеОповещенийОбОбновлениях() Экспорт

	Попытка
		ФормированиеУведомлений();
	Исключение
		ЗаписьЖурналаРегистрации(
			"КонтрольРелизов.ФормированиеУведомлений", 
			УровеньЖурналаРегистрации.Ошибка, 
			, 
			, 
			ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке())
		);
		ВызватьИсключение;
	КонецПопытки;

КонецПроцедуры

// Отправляет письма из очереди на электронную почту
//
Процедура ОтправкаПисемИзОчереди() Экспорт
	
	Попытка
		ОтправитьОжидающиеПисьма();
	Исключение
		ЗаписьЖурналаРегистрации(
			"КонтрольРелизов.ОтправкаПисемИзОчереди",
			УровеньЖурналаРегистрации.Ошибка,
			,
			,
			ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке())
		);
		ВызватьИсключение;
	КонецПопытки;
	
КонецПроцедуры

// Формирует уведомления для ответственных за обновления расширений конфигурации
//
Процедура ФормированиеОповещенийОбРасширениях() Экспорт

