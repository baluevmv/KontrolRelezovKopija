#Область ПрограммныйИнтерфейс

// Обрабатывает HTTP-запрос, динамически определяя и вызывая соответствующий метод API
// на основе URL и HTTP-метода. Используется как единая точка входа для API-запросов.
//
// Параметры:
//  HTTPЗапрос - HTTPЗапрос - входящий HTTP-запрос, содержащий:
//  ИмяМодуля - Строка - имя общего модуля, содержащего методы обработки
//
// Возвращаемое значение:
//  HTTPОтвет - результат выполнения соответствующего метода API  
//
Функция ОбработатьЗапросУниверсально(HTTPЗапрос, ИмяМодуля) Экспорт
	
	Попытка
		
		СтруктураМетаданных = ПолучитьМетаданныеЗапроса(HTTPЗапрос);
		
		Если СтруктураМетаданных.Шаблон = Неопределено Тогда
			ВызватьИсключение СтрШаблон("Не удалось опознать шаблон запроса: %1%2 к модулю: %3", HTTPЗапрос.БазовыйURL, HTTPЗапрос.ОтносительныйURL, ИмяМодуля);
		КонецЕсли;
		
		ИмяФункции = СтрШаблон("%1%2", СтруктураМетаданных.Шаблон.Имя, HTTPЗапрос.HTTPМетод);
		ИмяМетода = СтрШаблон("%1.%2", ИмяМодуля, ИмяФункции);
		
		Результат = ВыполнитьМетод(ИмяМетода, HTTPЗапрос);
		
		Возврат Результат;
		
	Исключение
		
		ЗаписьЖурналаРегистрации("API.ОбработатьЗапросУниверсально", УровеньЖурналаРегистрации.Ошибка,,,
			СтрШаблон("Выполнение метода: %1 - Ошибка | %2", ИмяМетода,ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке())));
		
	КонецПопытки;
	
КонецФункции

// Выполняет указанный метод API с обработкой HTTP-запроса и возвращает стандартизированный ответ
// Обеспечивает безопасное выполнение методов API с обработкой ошибок и логированием
//
// Параметры:
//  Метод - Строка - полное имя метода API в формате "Модуль.ИмяМетода"
//  HTTPЗапрос - HTTPЗапрос - объект входящего HTTP-запроса
//
// Возвращаемое значение:
//  HTTPОтвет - стандартизированный HTTP-ответ, содержащий:
//
Функция ВыполнитьМетод(Метод, HTTPЗапрос) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	ДанныеСтрокой = HTTPЗапрос.ПолучитьТелоКакСтроку();
	
	ОбщиеПараметрыОшибки = Новый Соответствие;
	ОбщиеПараметрыОшибки.Вставить("ДанныеЗапроса", ДанныеСтрокой);
	
	Ошибка = "INTERNAL_SERVER_ERROR";
	КодОшибки = 500;
	ОписаниеОшибки = "";
	
	ПолноеОписаниеОшибки = Новый Массив();
	
	Попытка
		
		УстановитьБезопасныйРежим(Истина);
		Данные = Вычислить(СтрШаблон("%1(HTTPЗапрос)", Метод));
		УстановитьБезопасныйРежим(Ложь);
		Ответ  = СоздатьОтветHTTPСервиса(Данные);
		
	Исключение
		
		ОписаниеОшибки = ОписаниеОшибки();
		ПолноеОписаниеОшибки.Добавить(ОписаниеОшибки);
		ОбщиеПараметрыОшибки.Вставить("Ошибка", СтрСоединить(ПолноеОписаниеОшибки, Символы.ПС)); 
		
	КонецПопытки;
	
	Если ТипЗнч(Ответ) <> Тип("HTTPСервисОтвет") Тогда
		
		Ответ = СоздатьОтветHTTPСервиса(Ошибка, КодОшибки, ОбщиеПараметрыОшибки);
		
		Если НЕ ПустаяСтрока(ОписаниеОшибки) Тогда
			ЗаписьЖурналаРегистрации("API.ВыполнениеМетода", УровеньЖурналаРегистрации.Ошибка, , , ОписаниеОшибки);
		КонецЕсли;
		
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(ЛОЖЬ);
	
	Возврат Ответ;
	
КонецФункции

// Универсальное создание HTTP-ответа с поддержкой различных типов данных
// и обработкой ошибок в стандартизированном формате
//
// Параметры:
//  Данные - Произвольный - возвращаемые данные (строка, двоичные данные или произвольный объект)
//  Код - Число - HTTP-код состояния (по умолчанию 200)
//  Параметры - Структура - дополнительные параметры
//
// Возвращаемое значение:
//  HTTPОтвет - сформированный HTTP-ответ
//
Функция СоздатьОтветHTTPСервиса(Данные, Код = 200, Параметры = Неопределено) Экспорт
	
	Ответ = Новый HTTPСервисОтвет(Код);
	Если Параметры = Неопределено Тогда
		Параметры = Новый Соответствие;
	КонецЕсли;
	
	Если ТипЗнч(Данные) = Тип("Строка") Тогда
		
		Если Код >= 400 Тогда
			Ответ.Причина = Данные;
			Комментарий   = "Код состояния: " + Строка(Код) + " " + Данные;
			Если Параметры["ДанныеЗапроса"] <> Неопределено Тогда
				Комментарий = Комментарий + Символы.ПС + "Параметры запроса: " + Символы.ПС + Параметры["ДанныеЗапроса"]; 
			КонецЕсли;
			Если Параметры["Ошибка"] <> Неопределено Тогда
				Комментарий = Комментарий + Символы.ПС + "Описание ошибки: " + Символы.ПС + Параметры["Ошибка"]; 
			КонецЕсли;
			Ответ.УстановитьТелоИзСтроки(Комментарий);
		Иначе
			ТекДанные = Данные;
			Ответ.УстановитьТелоИзСтроки(ТекДанные);
		КонецЕсли;
		
	ИначеЕсли ТипЗнч(Данные) = Тип("ДвоичныеДанные") Тогда
		Ответ.УстановитьТелоИзДвоичныхДанных(Данные);
	Иначе
		СтрокаДанных = ОбщегоНазначения.ЗначениеВJSON(Данные);
		Ответ.УстановитьТелоИзСтроки(СтрокаДанных, КодировкаТекста.UTF8, ИспользованиеByteOrderMark.НеИспользовать);
		Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
	КонецЕсли;
	
	Если Параметры <> Неопределено Тогда
		Если Параметры["ContentType"] <> Неопределено Тогда
			Ответ.Заголовки.Вставить("Content-Type",  Параметры["ContentType"]);
		ИначеЕсли Параметры["ТипКонтента"] <> Неопределено Тогда
			Ответ.Заголовки.Вставить("Content-Type",  Параметры["ТипКонтента"]);
		КонецЕсли;		
	КонецЕсли;
	
	Если Ответ.Заголовки["Content-Type"] = Неопределено Тогда
		Ответ.Заголовки.Вставить("Content-Type","text/html; charset=utf-8");
	КонецЕсли;
	
	Возврат Ответ;
КонецФункции

// Обрабатывает POST-запрос для получения характеристик информационной системы по строке подключения.
// Возвращает данные в формате JSON или текст ошибки в случае исключения.
//
// Параметры:
//  HTTPЗапрос - HTTPЗапрос - входящий HTTP-запрос, содержащий в теле JSON с параметрами:
//    * СтрокаСоединения - Строка - строка подключения к информационной системе
//    * ИмяНабораХарактеристик - Строка - наименование набора характеристик
//    * ИмяХарактеристики - Строка - наименование искомой характеристики
//
// Возвращаемое значение:
//  Строка - JSON-представление массива значений характеристик при успешном выполнении
//  Строка - текст ошибки с описанием проблемы при возникновении исключения
//
Функция rc_StatePOST(HTTPЗапрос) Экспорт
	
	ТелоHTTPЗапроса = HTTPЗапрос.ПолучитьТелоКакСтроку();
	Попытка
		
		Результат = Новый Структура;
		РаботаСJSON.ОбработатьСообщениеОт1С(ТелоHTTPЗапроса, Результат);
		
		Возврат ?(Результат.Количество() > 0, ОбщегоНазначения.ЗначениеВJSON(Результат), Неопределено);
		
	Исключение
		
		ТекстОшибки = "Ошибка при выполнении запроса: " + ОписаниеОшибки();
		ЗаписьЖурналаРегистрации("API.rc_State", УровеньЖурналаРегистрации.Ошибка, , , ТекстОшибки);
		
		Возврат ТекстОшибки;
		
	КонецПопытки;
	
КонецФункции

Функция rc_StateGET(HTTPЗапрос) Экспорт
	Возврат Неопределено;
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ПолучитьМетаданныеЗапроса(Запрос)
	
	СтруктураМетаданных = Новый Структура("Сервис, Шаблон");
	HTTPСервисы = Метаданные.HTTPСервисы;
	
	Для Каждого Сервис ИЗ HTTPСервисы Цикл
		
		ПозицияHS = СтрНайти(Запрос.БазовыйURL, "/hs/");
		КорневойURL = Сред(Запрос.БазовыйURL, ПозицияHS + 4);
		
		Если ВРЕГ(Сервис.КорневойURL) = ВРЕГ(КорневойURL) Тогда
			
			СтруктураМетаданных.Сервис = Сервис;
			ШаблонURL                  = Запрос.ОтносительныйURL;     
			
			Для Каждого ПараметрURL ИЗ Запрос.ПараметрыURL Цикл
				ШаблонURL = СтрЗаменить(ШаблонURL, ПараметрURL.Значение, ?(ПараметрURL.Ключ = "*", "*", "{VAR}")); 
			КонецЦикла;
			
			ШаблонБезСлешей = ВРЕГ(УбратьИзСтроки(ШаблонURL, "/,*"));
			Для Каждого Шаблон ИЗ Сервис.ШаблоныURL Цикл
				Если ВРЕГ(УбратьИзСтроки(ПолучитьШаблонURLДляСравнения(Шаблон.Шаблон), "/,*")) = ШаблонБезСлешей Тогда
					
					СтруктураМетаданных.Шаблон = Шаблон;
					Прервать;
					
				КонецЕсли;
			КонецЦикла;
			Прервать;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат СтруктураМетаданных;
	
КонецФункции

Функция ПолучитьШаблонURLДляСравнения(ШаблонURL)
	
	ЧастиURL = СтрРазделить(ШаблонURL, "/");
	Для й = 0 ПО ЧастиURL.ВГраница() Цикл
		Если СтрНачинаетсяС(ЧастиURL[й], "{") Тогда
			ЧастиURL[й] = "{VAR}";
		КонецЕсли;
	КонецЦикла;
	
	Возврат СтрСоединить(ЧастиURL, "/");
	
КонецФункции

Функция УбратьИзСтроки(Знач Строка, Знач УбираемыеЗначения, Знач Разделитель = ",")
	
	Если ТипЗнч(УбираемыеЗначения) = Тип("Строка") Тогда
		УбираемыеЗначения = СтрРазделить(УбираемыеЗначения, Разделитель, ЛОЖЬ);
	КонецЕсли;
	
	Для Каждого ТекЗначение ИЗ УбираемыеЗначения Цикл
		Строка = СтрЗаменить(Строка, ТекЗначение, "");
	КонецЦикла;
	
	Возврат Строка;
	
КонецФункции

#КонецОбласти